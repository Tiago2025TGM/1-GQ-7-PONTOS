# ──────────────────────────────────────────────
# BookShelf — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# ──────────────────────────────────────────────

# Back4App (https://www.back4app.com)
# Acesse: App Settings → Security & Keys
NEXT_PUBLIC_BACK4APP_APP_ID=SEU_APPLICATION_ID_AQUI
NEXT_PUBLIC_BACK4APP_JS_KEY=SEU_JAVASCRIPT_KEY_AQUI
NEXT_PUBLIC_BACK4APP_SERVER_URL=https://parseapi.back4app.com

# MailboxLayer (https://mailboxlayer.com/)
# Crie uma conta gratuita e copie sua Access Key
NEXT_PUBLIC_MAILBOXLAYER_KEY=SUA_ACCESS_KEY_AQUI
